# Port d'écoute
PORT=3001

# Chemin vers le binaire LilyPond (défaut: lilypond dans le PATH)
LILYPOND_BIN=lilypond

# Timeout de compilation en ms (défaut: 15000)
COMPILE_TIMEOUT=15000

# Requêtes max par minute par IP (défaut: 60)
RATE_LIMIT=60

# Origines CORS autorisées (séparées par virgule)
ALLOWED_ORIGINS=http://localhost:3000,https://getharmonia.app
